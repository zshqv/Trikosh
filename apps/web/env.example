# ─────────────────────────────────────────────────────────────
# Trikosh — environment variables reference
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local or any file with real credentials.
# ─────────────────────────────────────────────────────────────

# ── Clerk Authentication ──────────────────────────────────────
# Obtain from https://dashboard.clerk.com → your app → API Keys
# The publishable key is safe to expose in client-side bundles.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# The secret key must NEVER appear in client-side code.
# Server-side only (API routes, middleware, server components).
CLERK_SECRET_KEY=sk_test_your_secret_key_here

# ── PostgreSQL / Neon Database ────────────────────────────────
# Full connection string (preferred). Include ?sslmode=require
# for Neon. Supports both pooled and direct connection strings.
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Individual connection params — used as fallback when
# DATABASE_URL is not set (local development without Neon).
DB_HOST=your-db-host.neon.tech
DB_PORT=5432
DB_NAME=neondb
DB_USER=your_db_user
DB_PASSWORD=your_db_password
